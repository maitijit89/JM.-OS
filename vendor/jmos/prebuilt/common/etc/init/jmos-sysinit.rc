# JM OS Performance Optimization Script

on post-fs-data
    # Initialize zRAM with a high-performance compression algorithm (zstd or lz4)
    # Defaulting to lz4 for compatibility and speed
    write /sys/block/zram0/comp_algorithm lz4
    # Set zRAM size (e.g., 2GB = 2147483648 bytes)
    # This is typically handled by the kernel, but we can hint it
    write /sys/block/zram0/disksize 2147483648

on property:sys.boot_completed=1
    # Switch to 'schedutil' governor for a balance of power and performance
    # This loop tries to apply it to all clusters
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor schedutil
    write /sys/devices/system/cpu/cpu4/cpufreq/scaling_governor schedutil
    
    # Background Task Optimization
    # Reduce latency for UI tasks
    write /dev/stune/foreground/schedtune.boost 10
    write /dev/stune/top-app/schedtune.boost 20

    # I/O Tuning
    # Increase read-ahead for faster app launches
    write /sys/block/mmcblk0/queue/read_ahead_kb 2048
    write /sys/block/dm-0/queue/read_ahead_kb 2048
